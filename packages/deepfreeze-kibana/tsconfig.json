{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react",
    "declaration": true,
    "declarationMap": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./target/types",
    "baseUrl": ".",
    "paths": {
      "@kbn/*": ["./typestubs/*"]
    }
  },
  "include": ["common/**/*", "public/**/*", "server/**/*"],
  "exclude": ["target/**/*", "build/**/*", "node_modules/**/*"]
}
